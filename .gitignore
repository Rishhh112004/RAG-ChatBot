# ================================
# 🔹 VIRTUAL ENVIRONMENT (IMPORTANT)
# ================================
venv/
env/
.venv/

# ================================
# 🔹 PYTHON CACHE FILES
# ================================
__pycache__/
*.pyc
*.pyo
*.pyd

# ================================
# 🔹 MODEL FILES (VERY LARGE - DO NOT PUSH)
# ================================
models/*.gguf

# ================================
# 🔹 VECTOR DATABASE FILES (REGENERATABLE)
# ================================
vector_store/
*.bin
*.index
*.pkl

# ================================
# 🔹 DATA FILES (OPTIONAL - depends on use)
# ================================
data/*.txt

# ================================
# 🔹 ENVIRONMENT VARIABLES / SECRETS
# ================================
.env

# ================================
# 🔹 IDE / EDITOR FILES
# ================================
.vscode/
.idea/

# ================================
# 🔹 SYSTEM FILES
# ================================
.DS_Store
Thumbs.db

# ================================
# 🔹 LOGS & TEMP FILES
# ================================
*.log
*.tmp
*.temp

# ================================
# 🔹 TEST CACHE / COVERAGE
# ================================
.coverage
htmlcov/

# ================================
# 🔹 NOTEBOOKS
# ================================
.ipynb_checkpoints/

# ================================
# 🔹 MISC
# ================================
*.sqlite3